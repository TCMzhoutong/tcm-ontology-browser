therTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00009":{"id":"V027-N00009","localId":"V027-N00009","label":"四神聪","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"四神聪","preferredName":"四神聪","aliases":"神聪","englishNames":"","pinyinNames":"Sìshéncōng","definitions":"在头部，百会（GV20）前后左右各旁开1寸，共4穴。（见GB/T 22163—2008，图4-1）\n注：后神聪在前后发际正中连线的中点处，前顶（GV21）后0.5寸为前神聪。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN1","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00010":{"id":"V027-N00010","localId":"V027-N00010","label":"当阳","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"当阳","preferredName":"当阳","aliases":"","englishNames":"","pinyinNames":"Dāngyáng","definitions":"在头部，瞳孔直上，前发际上1寸。（见 GB/T 22163—2008，图4-2）\n注：头临泣（GB15）直上0.5寸，横平上星（GV23）。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN2","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00011":{"id":"V027-N00011","localId":"V027-N00011","label":"鱼腰","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"鱼腰","preferredName":"鱼腰","aliases":"光明； 吊睛","englishNames":"","pinyinNames":"Yúyāo","definitions":"在头部，瞳孔直上，眉毛中。（见GB/T 22163—2008，图4-2）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN4","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00012":{"id":"V027-N00012","localId":"V027-N00012","label":"太阳","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"太阳","preferredName":"太阳","aliases":"","englishNames":"","pinyinNames":"Tàiyáng","definitions":"在头部，眉梢与目外眦之间，向后约一横指（中指）的凹陷中。（见GB/T 22163—2008，图4-3）\n注：丝竹空（TE23）与瞳子髎（GB1）连线中点向外约一横指处。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN5","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00013":{"id":"V027-N00013","localId":"V027-N00013","label":"耳尖","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"耳尖","preferredName":"耳尖","aliases":"","englishNames":"","pinyinNames":"Ěrjiān","definitions":"在耳区，在外耳轮的最高点。（见 GB/T 22163—2008，图4-3）\n注：耳郭向前对折时，在耳郭上部尖端处。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN6","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00014":{"id":"V027-N00014","localId":"V027-N00014","label":"球后","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"球后","preferredName":"球后","aliases":"","englishNames":"","pinyinNames":"Qiúhòu","definitions":"在面部，眼球与眶下缘之间，眶下缘外 1/4与内3/4交界处。（见 GB/T 22163—2008，图4-2）\n注：承泣（ST1）外上方。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN7","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00015":{"id":"V027-N00015","localId":"V027-N00015","label":"上迎香","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"上迎香","preferredName":"上迎香","aliases":"鼻通； 鼻穿","englishNames":"","pinyinNames":"Shàngyíngxiāng","definitions":"在面部，鼻翼软骨与鼻甲的交界处，近鼻翼沟上端处。（见 GB/T 22163—2008，图4-2）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN8","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00016":{"id":"V027-N00016","localId":"V027-N00016","label":"内迎香","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"内迎香","preferredName":"内迎香","aliases":"迎香","englishNames":"","pinyinNames":"Nèiyíngxiāng","definitions":"在鼻孔内，鼻翼软骨与鼻甲交界的黏膜处。（见GB/T 22163—2008，图4-2）\n注：与上迎香（EX-HN8）相对处的鼻黏膜上。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN9","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00017":{"id":"V027-N00017","localId":"V027-N00017","label":"聚泉","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"聚泉","preferredName":"聚泉","aliases":"","englishNames":"","pinyinNames":"Jùquán","definitions":"在口腔内，舌背正中缝的中点处。（见 GB/T 22163—2008，图4-2）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN10","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00018":{"id":"V027-N00018","localId":"V027-N00018","label":"海泉","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"海泉","preferredName":"海泉","aliases":"","englishNames":"","pinyinNames":"Hǎiquán","definitions":"在口腔内，舌下系带中点处。（见 GB/T 22163—2008，图4-2）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN11","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00019":{"id":"V027-N00019","localId":"V027-N00019","label":"金津玉液","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"金津玉液","preferredName":"金津玉液","aliases":"廉泉","englishNames":"","pinyinNames":"Jīnjīn Yùyè","definitions":"在口腔内，舌下系带两侧的静脉上，左曰金津，右曰玉液。（见GB/T 22163—2008，图4-2）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN12；EX-HN13","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00020":{"id":"V027-N00020","localId":"V027-N00020","label":"翳明","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"翳明","preferredName":"翳明","aliases":"","englishNames":"","pinyinNames":"Yìmíng","definitions":"在项部，翳风（TE17）后1寸。（见GB/T 22163—2008，图4-3）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN14","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00021":{"id":"V027-N00021","localId":"V027-N00021","label":"安眠","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"安眠","preferredName":"安眠","aliases":"","englishNames":"","pinyinNames":"Ānmián","definitions":"在项部，当翳风（TE17）和风池（GB20）连线的中点（见图1）。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00022":{"id":"V027-N00022","localId":"V027-N00022","label":"牵正","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"牵正","preferredName":"牵正","aliases":"","englishNames":"","pinyinNames":"Qiānzhèng","definitions":"在面颊部，耳垂前方0.5～1寸，与耳垂中点相平处（见图1）。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00023":{"id":"V027-N00023","localId":"V027-N00023","label":"新设","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"新设","preferredName":"新设","aliases":"新识","englishNames":"","pinyinNames":"Xīnshè","definitions":"在项部，当第4颈椎横突端，斜方肌外缘（见图2）。\n注：正坐或俯伏，于风池（GB20）直下，后发际下1.5寸，斜方肌外缘取穴。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00024":{"id":"V027-N00024","localId":"V027-N00024","label":"颈百劳","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"颈百劳","preferredName":"颈百劳","aliases":"百劳","englishNames":"","pinyinNames":"Jǐngbǎiláo","definitions":"在项部，第7颈椎棘突直上2寸，后正中线旁开1寸。（见 GB/T 22163—2008，图4-5）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-HN15","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00025":{"id":"V027-N00025","localId":"V027-N00025","label":"血压点","parent":"V027-N00008","parentName":"头颈部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜头颈部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"血压点","preferredName":"血压点","aliases":"","englishNames":"","pinyinNames":"Xuèyādiǎn","definitions":"在项部，第6、7 颈椎棘突间旁开2寸（见图2）。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00026":{"id":"V027-N00026","localId":"V027-N00026","label":"胸腹部穴","parent":"V027-N00007","parentName":"名称与定位","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"胸腹部穴","preferredName":"胸腹部穴","aliases":"","englishNames":"","pinyinNames":"","definitions":"","definitionsLabel":"概念定义","definitionSources":"","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00027":{"id":"V027-N00027","localId":"V027-N00027","label":"提托","parent":"V027-N00026","parentName":"胸腹部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜胸腹部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"提托","preferredName":"提托","aliases":"","englishNames":"","pinyinNames":"Títuō","definitions":"在下腹部，脐中下3寸，前正中线旁开4寸（见图3）。\n注：仰卧，在关元（CV4）旁开4寸处取穴。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00028":{"id":"V027-N00028","localId":"V027-N00028","label":"子宫","parent":"V027-N00026","parentName":"胸腹部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜胸腹部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"子宫","preferredName":"子宫","aliases":"","englishNames":"","pinyinNames":"Zǐgōng","definitions":"在下腹部，脐中下4寸，前正中线旁开 3寸。（见 GB/T 22163—2008，图4-4）\n注：足阳明胃经线与足太阴脾经线中间，横平中极（CV3）。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-CA1","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00029":{"id":"V027-N00029","localId":"V027-N00029","label":"背部穴","parent":"V027-N00007","parentName":"名称与定位","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"背部穴","preferredName":"背部穴","aliases":"","englishNames":"","pinyinNames":"","definitions":"","definitionsLabel":"概念定义","definitionSources":"","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00030":{"id":"V027-N00030","localId":"V027-N00030","label":"定喘","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"定喘","preferredName":"定喘","aliases":"喘息","englishNames":"","pinyinNames":"Dìngchuǎn","definitions":"在脊柱区，横平第7颈椎棘突下，后正中线旁开 0.5寸。（见 GB/T 22163—2008，图4-5）\n注：大椎（GV14）旁开0.5寸。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B1","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00031":{"id":"V027-N00031","localId":"V027-N00031","label":"夹脊","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"夹脊","preferredName":"夹脊","aliases":"华佗夹脊； 佗脊","englishNames":"","pinyinNames":"Jiájǐ","definitions":"在脊柱区，第1胸椎至第5腰椎棘突下两侧，后正中线旁开0.5寸，一侧17穴。（见 GB/T 22163—2008，图4-5）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B2","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00032":{"id":"V027-N00032","localId":"V027-N00032","label":"胃脘下俞","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"胃脘下俞","preferredName":"胃脘下俞","aliases":"胃管下俞； 胃下俞","englishNames":"","pinyinNames":"Wèiwǎnxiàshù","definitions":"在脊柱区，横平第8胸椎棘突下，后正中线旁开 1.5寸。（见 GB/T 22163—2008，图4-5）\n注：在膈俞（BL17）与肝俞（BL18）中间。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B3","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00033":{"id":"V027-N00033","localId":"V027-N00033","label":"接脊","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"接脊","preferredName":"接脊","aliases":"","englishNames":"","pinyinNames":"Jiējí","definitions":"在背部，第12胸椎棘突下凹陷中（见图4）。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00034":{"id":"V027-N00034","localId":"V027-N00034","label":"痞根","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"痞根","preferredName":"痞根","aliases":"","englishNames":"","pinyinNames":"Pǐgēn","definitions":"在腰区，横平第1腰椎棘突下，后正中线旁开3.5寸。（见 GB/T 22163—2008，图4-5）\n注：肓门（BL51）外 0.5寸。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B4","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00035":{"id":"V027-N00035","localId":"V027-N00035","label":"腰宜","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"腰宜","preferredName":"腰宜","aliases":"","englishNames":"","pinyinNames":"Yāoyí","definitions":"在腰区，横平第4腰椎棘突下，后正中线旁开3寸。（见 GB/T 22163—2008，图4-5）\n注：大肠俞（BL25）外1.5寸。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B6","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00036":{"id":"V027-N00036","localId":"V027-N00036","label":"腰眼","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"腰眼","preferredName":"腰眼","aliases":"腰目","englishNames":"","pinyinNames":"Yāoyǎn","definitions":"在腰区，横平第4腰椎棘突下，后正中线旁开约3.5寸凹陷中。（见GB/T 22163—2008，图4-5）\n注：直立时，约横平腰阳关（GV3）两侧呈现的圆形凹陷中。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B7","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00037":{"id":"V027-N00037","localId":"V027-N00037","label":"十七椎","parent":"V027-N00029","parentName":"背部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜背部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"十七椎","preferredName":"十七椎","aliases":"十七椎下","englishNames":"","pinyinNames":"Shíqīzhuī","definitions":"在腰区，第5腰椎棘突下凹陷中。（见GB/T 22163—2008，图4-5）\n注：腰阳关（GV3）下1个棘突下凹陷中。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-B8","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00038":{"id":"V027-N00038","localId":"V027-N00038","label":"肩胛部穴","parent":"V027-N00007","parentName":"名称与定位","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"肩胛部穴","preferredName":"肩胛部穴","aliases":"","englishNames":"","pinyinNames":"","definitions":"","definitionsLabel":"概念定义","definitionSources":"","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00039":{"id":"V027-N00039","localId":"V027-N00039","label":"肩前","parent":"V027-N00038","parentName":"肩胛部穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜肩胛部穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"肩前","preferredName":"肩前","aliases":"前腋； 腋缝； 前腋缝； 肩内陵","englishNames":"","pinyinNames":"Jiānqián","definitions":"在肩部，当腋前皱襞尽端直上 1.5寸处（见图5）。","definitionsLabel":"概念定义","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00040":{"id":"V027-N00040","localId":"V027-N00040","label":"上肢穴","parent":"V027-N00007","parentName":"名称与定位","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"上肢穴","preferredName":"上肢穴","aliases":"","englishNames":"","pinyinNames":"","definitions":"","definitionsLabel":"概念定义","definitionSources":"","otherTermTypes":"","extraInfo":"","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00041":{"id":"V027-N00041","localId":"V027-N00041","label":"肘尖","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"肘尖","preferredName":"肘尖","aliases":"","englishNames":"","pinyinNames":"Zhǒujiān","definitions":"在肘后区，尺骨鹰嘴的尖端。（图见 GB/T 22163—2008，图4-6）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE1","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00042":{"id":"V027-N00042","localId":"V027-N00042","label":"二白","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"二白","preferredName":"二白","aliases":"","englishNames":"","pinyinNames":"Èrbái","definitions":"在前臂前区，腕掌侧远端横纹上4寸，桡侧腕屈肌腱的两侧，一肢2穴。（图见 GB/T 22163—2008，图4-7）\n注：屈腕，显现两条肌腱，其中一个穴点在间使（PC5）后1寸两腱间，另一穴点在桡侧腕屈肌腱的桡侧。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE2","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00043":{"id":"V027-N00043","localId":"V027-N00043","label":"中泉","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"中泉","preferredName":"中泉","aliases":"","englishNames":"","pinyinNames":"Zhōngquán","definitions":"在前臂后区，腕背侧远端横纹上，指总伸肌腱桡侧的凹陷中。（见 GB/T 22163—2008，图4-8）\n注：阳溪（LI5）与阳池（TE4）连线的中点处。","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE3","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00044":{"id":"V027-N00044","localId":"V027-N00044","label":"中魁","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"中魁","preferredName":"中魁","aliases":"","englishNames":"","pinyinNames":"Zhōngkuí","definitions":"在手指，中指背面，近侧指间关节的中点处。（见 GB/T 22163—2008，图4-8）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE4","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00045":{"id":"V027-N00045","localId":"V027-N00045","label":"大骨空","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"大骨空","preferredName":"大骨空","aliases":"","englishNames":"","pinyinNames":"Dàgǔkōng","definitions":"在手指，拇指背面，掌指关节的中点处。（见 GB/T 22163—2008，图4-8）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE5","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00046":{"id":"V027-N00046","localId":"V027-N00046","label":"小骨空","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"小骨空","preferredName":"小骨空","aliases":"","englishNames":"","pinyinNames":"Xiǎogǔkōng","definitions":"在手指，小指背面，近侧指间关节的中点处。（见 GB/T 22163—2008，图4-8）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE6","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00047":{"id":"V027-N00047","localId":"V027-N00047","label":"腰痛点","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":"腰痛点","preferredName":"腰痛点","aliases":"","englishNames":"","pinyinNames":"Yāotòngdiǎn","definitions":"在手背，第2、3掌骨间及第4、5掌骨间，腕背侧远端横纹与掌指关节的中点处，一手2穴。（见 GB/T 22163—2008，图4-8）","definitionsLabel":"腧穴定位","definitionSources":"GB/T 40997-2021","otherTermTypes":"","extraInfo":"经外奇穴代码: EX-UE7","differentForms":"","jianboSources":"","attachmentInfo":"","imagePaths":[]},"V027-N00048":{"id":"V027-N00048","localId":"V027-N00048","label":"外劳宫","parent":"V027-N00040","parentName":"上肢穴","lineagePath":"GBT40997-2021-经外奇穴名称与定位｜名称与定位｜上肢穴","vocabularyName":"GBT40997-2021-经外奇穴名称与定位","conceptName":